#!/usr/bin/env python3
"""
Tower - Live conversation mirror for AI coding sessions.

Tails JSONL transcripts from Claude Code and renders readable output in real-time.
Run in a split terminal pane to always see your full conversation, even after
/clear or /compact wipes your scrollback.

Usage:
    tower                     # Watch most recent session (basic mode)
    tower --tui               # Watch most recent session (interactive TUI)
    tower -i                  # Alias for --tui
    tower 1                   # Watch most recent from --list
    tower <session-id>        # Watch by partial session ID
    tower --list              # List recent sessions
    tower --list 20           # List last 20 sessions

Alias: tw (add to .zshrc: alias tw='tower')
"""

import json
import os
import sys
import time
import signal
from pathlib import Path

# Import shared parser (same directory)
sys.path.insert(0, str(Path(__file__).parent))
from tower_parser import (
    parse_entry, render_entry_basic, find_latest_transcript,
    find_transcript_by_id, get_sorted_transcripts, list_sessions,
    BOLD, DIM, RESET, RULE,
)


def tail_transcript(path: str):
    """Tail a JSONL transcript file and render new entries."""
    print(f"{BOLD}Watching:{RESET} {path}")
    print(f"{DIM}Session: {Path(path).stem}{RESET}")
    print(f"{RULE}\n")

    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    output = render_entry_basic(entry)
                    if output:
                        print(output, flush=True)
                except json.JSONDecodeError:
                    continue

            print(f"\n{DIM}--- Live tail (waiting for new messages) ---{RESET}\n", flush=True)

            while True:
                line = f.readline()
                if line:
                    line = line.strip()
                    if line:
                        try:
                            entry = json.loads(line)
                            output = render_entry_basic(entry)
                            if output:
                                print(output, flush=True)
                        except json.JSONDecodeError:
                            pass
                else:
                    time.sleep(0.3)
    except FileNotFoundError:
        print("Waiting for transcript to be created...")


def launch_tui(path: str):
    """Launch the interactive TUI mode."""
    try:
        from tower_tui import TowerApp
    except ImportError:
        print("TUI mode requires textual. Install with:")
        print("  pip install textual")
        sys.exit(1)
    app = TowerApp(path)
    app.run()


def resolve_session(args: list[str]) -> str:
    """Resolve session args to a transcript file path."""
    if not args:
        path = find_latest_transcript()
        if not path:
            print("No transcripts found")
            sys.exit(1)
        return path

    query = args[0]
    if query.isdigit():
        idx = int(query) - 1
        transcripts = get_sorted_transcripts()
        if 0 <= idx < len(transcripts):
            return str(transcripts[idx])
        else:
            print(f"No session at index {query}. Use --list to see available.")
            sys.exit(1)
    else:
        path = find_transcript_by_id(query)
        if not path:
            if os.path.isfile(query):
                return query
            else:
                print(f"No transcript found for: {query}")
                sys.exit(1)
        return path


def main():
    signal.signal(signal.SIGINT, lambda *_: sys.exit(0))

    args = sys.argv[1:]
    tui_mode = False

    # Extract --tui / -i flag
    if "--tui" in args or "-i" in args:
        tui_mode = True
        args = [a for a in args if a not in ("--tui", "-i")]

    # Handle --list (always basic mode)
    if args and args[0] == "--list":
        list_sessions(int(args[1]) if len(args) > 1 else 10)
        return

    # Handle --help
    if args and args[0] in ("--help", "-h"):
        print(__doc__)
        return

    # Resolve session path
    path = resolve_session(args)

    if tui_mode:
        launch_tui(path)
    else:
        tail_transcript(path)


if __name__ == "__main__":
    main()
